# Salesforce QA/UAT – copy to .env and set values (do not commit .env)
SALESFORCE_BASE_URL=https://login.salesforce.com
# For custom/community: https://yourdomain.my.salesforce.com or https://test.salesforce.com

SALESFORCE_USERNAME=your-username@example.com
SALESFORCE_PASSWORD=your-password

# New Opportunity test: Account lookup search text (must match at least one Account in the org)
SALESFORCE_TEST_ACCOUNT_SEARCH=Acme

# Optional: Stage label as shown in UI (default Prospecting)
# SALESFORCE_OPPORTUNITY_STAGE=Prospecting

# After login, open a specific org / Lightning home (recommended for multi-org sandboxes).
# Used as the Lightning origin for New Opportunity (same as Case when Case URL is not set).
# SALESFORCE_LIGHTNING_HOME_URL=https://yourorg--qa.sandbox.lightning.force.com/lightning/page/home

# Optional: paste the same URL you use for Case creation (…/lightning/o/Case/new). New Opportunity
# will use that host so both flows hit the same org.
# SALESFORCE_CASE_NEW_URL=https://yourorg--qa.sandbox.lightning.force.com/lightning/o/Case/new

# Optional: custom login URL (e.g. My Domain)
# SALESFORCE_BASE_URL=https://yourorg.lightning.force.com
